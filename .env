# ── Application ──────────────────────────
NODE_ENV=development
API_PORT=3000

# ── Database ─────────────────────────────
DB_NAME=autoscan_db
DB_USER=autoscan_user
DB_PASSWORD=autoscan_pass

# ── Auth ─────────────────────────────────
JWT_SECRET=change_this_in_production

# ── Firebase ─────────────────────────────
FIREBASE_PROJECT_ID=autoscan-pro
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=firebase@autoscan.iam.gserviceaccount.com

# ── OBD-II Mock ──────────────────────────
MOCK_OBD_ENABLED=true

# ── pgAdmin (dev only) ───────────────────
PGADMIN_EMAIL=admin@autoscan.local
PGADMIN_PASSWORD=admin123
